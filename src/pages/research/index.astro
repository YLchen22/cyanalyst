---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import Search from '../../components/Search.astro';
import { getCollection } from 'astro:content';
import { r2Url } from '../../config';

const base = import.meta.env.BASE_URL;

const [daily, weekly, special] = await Promise.all([
  getCollection('daily'),
  getCollection('weekly'),
  getCollection('special'),
]);

const allReports = [
  ...daily.map(e => ({ ...e.data, collection: 'daily', id: e.id })),
  ...weekly.map(e => ({ ...e.data, collection: 'weekly', id: e.id })),
  ...special.map(e => ({ ...e.data, collection: 'special', id: e.id })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const categories = [
  { key: 'daily', label: '日报', count: daily.length },
  { key: 'weekly', label: '周报', count: weekly.length },
  { key: 'special', label: '专题', count: special.length },
];
---

<BaseLayout title="研报 · CyAnalyst">
  <h1 class="text-2xl font-bold text-slate-900 mb-2">研报中心</h1>
  <p class="text-slate-500 mb-6">共 {allReports.length} 篇研报</p>

  <!-- Category filter -->
  <div class="flex items-center gap-2 mb-6">
    <a href={`${base}research/`} class="px-3 py-1 text-sm bg-slate-900 text-white rounded-full">全部</a>
    {categories.map(cat => (
      <a href={`${base}research/${cat.key}/`} class="px-3 py-1 text-sm bg-slate-100 text-slate-600 rounded-full hover:bg-slate-200 transition-colors">
        {cat.label} ({cat.count})
      </a>
    ))}
  </div>

  <!-- Search -->
  <Search />

  <!-- Report list -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
    {allReports.map(report => (
      <ResearchCard
        title={report.title}
        date={report.date}
        category={report.collection}
        tags={report.tags}
        summary={report.summary}
        url={r2Url(report.collection, report.id)}
        external={true}
      />
    ))}
  </div>
</BaseLayout>
