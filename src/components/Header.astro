---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname.replace(base, '/');

const navItems = [
  { label: '首页', href: `${base}`, match: '/' },
  { label: '研报', href: `${base}research/`, match: '/research' },
  { label: '关于', href: `${base}about/`, match: '/about' },
];

function isActive(match: string): boolean {
  if (match === '/') return pathname === '/';
  return pathname.startsWith(match);
}
---

<header class="bg-slate-900 text-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <a href={`${base}`} class="flex items-center gap-2 font-bold text-lg tracking-tight">
      <span class="text-blue-400">Cy</span><span>Analyst</span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded-md transition-colors ${
              isActive(item.match)
                ? 'bg-slate-700 text-white'
                : 'text-slate-300 hover:text-white hover:bg-slate-800'
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
