---
interface Props {
  title: string;
  date: Date;
  category: string;
  tags?: string[];
  summary?: string;
  url: string;
  external?: boolean;
}

const { title, date, category, tags = [], summary = '', url, external = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const categoryStyles: Record<string, string> = {
  daily: 'bg-blue-100 text-blue-700',
  weekly: 'bg-purple-100 text-purple-700',
  special: 'bg-amber-100 text-amber-700',
};

const categoryLabels: Record<string, string> = {
  daily: '日报',
  weekly: '周报',
  special: '专题',
};

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const linkAttrs = external ? { target: '_blank', rel: 'noopener' } : {};
---

<a href={url} {...linkAttrs} class="block bg-white rounded-xl border border-slate-200 p-5 hover:shadow-md hover:border-slate-300 transition-all group">
  <div class="flex items-center gap-2 mb-2 text-xs">
    <span class={`px-2 py-0.5 rounded-full font-medium ${categoryStyles[category] || 'bg-slate-100 text-slate-600'}`}>
      {categoryLabels[category] || category}
    </span>
    <span class="text-slate-400">{dateStr}</span>
  </div>
  <h3 class="font-semibold text-slate-900 group-hover:text-blue-600 transition-colors mb-1.5">
    {title}
  </h3>
  {
    summary && (
      <p class="text-sm text-slate-500 line-clamp-2 mb-2">{summary}</p>
    )
  }
  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag) => (
          <span class="text-xs text-slate-400 bg-slate-50 px-1.5 py-0.5 rounded">#{tag}</span>
        ))}
      </div>
    )
  }
</a>
