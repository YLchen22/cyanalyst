---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-400 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 text-sm flex flex-col sm:flex-row items-center justify-between gap-2">
    <p>© {year} CyAnalyst · 仅供学习参考，不构成投资建议</p>
    <div class="flex items-center gap-4">
      <a href={`${base}about/`} class="hover:text-white transition-colors">关于</a>
      <a href="https://github.com/cyanalyst" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
    </div>
  </div>
</footer>
