# CyAnalyst — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ==================== Cloudflare R2 ====================
# 从 Cloudflare Dashboard 获取: R2 > Manage R2 API Tokens

# Cloudflare Account ID（Dashboard 右侧栏可见）
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 API Token — Access Key ID
R2_ACCESS_KEY_ID=your_access_key_id

# R2 API Token — Secret Access Key
R2_SECRET_ACCESS_KEY=your_secret_access_key

# R2 Bucket 名称
R2_BUCKET_NAME=cyanalyst-reports

# R2 公共访问 URL（开启 r2.dev 或绑定自定义域名后获得）
# 例如: https://pub-abc123def456.r2.dev
# 或:   https://r2.cyanalyst.com
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ==================== Resend (邮件推送，待配置) ====================
# RESEND_API_KEY=re_xxxxxxxxxxxx
